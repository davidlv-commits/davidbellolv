<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep normal routing for existing files and directories.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Short share URLs for private gift access.
  RewriteRule ^s/([A-Za-z0-9_-]{6,64})$ s/index.php?c=$1 [L,QSA]
</IfModule>
